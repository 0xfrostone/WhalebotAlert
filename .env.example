# --- ALCHEMY (RPC Ethereum) ---
ALCHEMY_WSS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
ADMIN_IDS=YOUR_ADMIN_CHAT_ID

# --- TELEGRAM BOT ---
# Token dari @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# --- PENGATURAN DETEKSI ---
# Minimum USD value untuk dianggap transaksi besar
MIN_USD_VALUE=100

# Minimum persentase dampak ke liquidity pool (0.00001 = 0.001%)
MIN_LP_IMPACT=0.00001

# Minimum Whale Score untuk kirim alert (0-100)
# For demo: 5 (permissive) | Production: 20-30 (stricter)
MIN_WHALE_SCORE=5
